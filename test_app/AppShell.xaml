<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="test_app.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:test_app"
    Shell.FlyoutBehavior="Disabled"
    xmlns:view="clr-namespace:test_app.View"
    Title="test_app"
    TabBarForegroundColor="Green"
    TabBarUnselectedColor="Gray"
    TabBarTitleColor="Green">


    <TabBar>
        <ShellContent
        Title="홈"
        ContentTemplate="{DataTemplate view:HomePage}"
        Icon="home_new.png"
        Route="HomePage"/>

        <ShellContent
        Title="기록"
        ContentTemplate="{DataTemplate view:CalendarPage}"
        Icon="book.png"/>

        <ShellContent
        Title="커뮤니티"
        ContentTemplate="{DataTemplate view:CommunityPage}"
        Icon="people.png"/>

        <ShellContent
        Title="전체"
        ContentTemplate="{DataTemplate view:OtherPage}"
        Icon="menu.png"/>
    </TabBar>
</Shell>
