<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="test_app.View.HTP_ResultPage"
             xmlns:viewmodel="clr-namespace:test_app.ViewModel"
             x:DataType="viewmodel:HTP_ViewModel"
             BackgroundColor="#F0F0F0"
             Shell.BackgroundColor="#F0F0F0"
             Title="HTP 테스트 결과">
    
    <VerticalStackLayout>
            <Image Source="person.png" 
               HeightRequest="130"
               Margin="0, 0, 0, -20"
               ZIndex="1"/>

            <Border WidthRequest="360"
                BackgroundColor="White" 
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <StackLayout Margin="30">
                    <StackLayout>
                        <Label Text="House"
                           FontAttributes="Bold"/>
                        <Label Text="{Binding HouseMsg}"/>
                    </StackLayout>

                    <Frame HeightRequest="1"
                       BackgroundColor="Transparent"
                       BorderColor="Transparent"/>

                    <StackLayout>
                        <Label Text="Tree"
                           FontAttributes="Bold"/>
                        <Label Text="{Binding TreeMsg}"/>
                    </StackLayout>

                    <Frame HeightRequest="1"
                       BackgroundColor="Transparent"
                       BorderColor="Transparent"/>

                    <StackLayout>
                        <Label Text="Person"
                           FontAttributes="Bold"/>
                        <Label Text="{Binding PersonMsg}"/>
                    </StackLayout>

                    <Border HeightRequest="1" 
                        BackgroundColor="LightGray"
                        Margin="0, 20"/>

                    <Label Text="{Binding OutputMsg}"/>
                </StackLayout>
            </Border>

        <Button 
                BackgroundColor="#4F7C2D" 
                Text="저장하기"
                HeightRequest="55"
                CornerRadius="20"
                Margin="20"/>
    </VerticalStackLayout>
</ContentPage>