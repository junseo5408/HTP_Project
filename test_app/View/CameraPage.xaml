<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="test_app.View.CameraPage"
             xmlns:viewmodel="clr-namespace:test_app.ViewModel"
             x:DataType="viewmodel:HTP_ViewModel"
             Shell.ForegroundColor="White"
             Shell.BackgroundColor="Black"
             BackgroundColor="black">
    
    <VerticalStackLayout>
        <toolkit:CameraView x:Name="MyCamera" 
                            MediaCaptured="MyCamera_MediaCaptured"
                            HeightRequest="600"/>
        <Grid Margin="40, 0, 40, 0">
            <ImageButton Command="{Binding OpenMediaPickerCommand}" 
                         Source="photo.png"
                         HeightRequest="45"
                         WidthRequest="45"
                         HorizontalOptions="Start"/>

            <ImageButton 
                         Source="shot_icon.png"
                         HeightRequest="70"
                         WidthRequest="70"
                         CornerRadius="35"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>