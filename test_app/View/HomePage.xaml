<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="test_app.View.HomePage"
             xmlns:viewmodel="clr-namespace:test_app.ViewModel"
             x:DataType="viewmodel:HomeViewModel"
             Title="" BackgroundColor="#F0F0F0">
    <ScrollView>
        <VerticalStackLayout>
            <Image HorizontalOptions="Start"  Source="logo1.png"/>

            <ImageButton 
            Command="{Binding GoHTPCommand}"
            WidthRequest="350"
            Source="banner1.png" 
            CornerRadius="20"
            Aspect="AspectFit"/>
            
            <Frame BackgroundColor="Transparent"
                   BorderColor="Transparent" HeightRequest="5"/>
            
            <ImageButton
            Command="{Binding GoRorschachCommand}"
            BackgroundColor="White"
            WidthRequest="350"
            Margin="0, 10, 0, 0"
            Source="banner2.png"
            CornerRadius="20"/>
            <Frame BackgroundColor="Transparent"
                   BorderColor="Transparent"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>